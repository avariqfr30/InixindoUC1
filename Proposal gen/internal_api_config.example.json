{
  "request_defaults": {
    "url": "https://xxx.com/api/Resource/dataset",
    "method": "POST",
    "body_encoding": "form",
    "params": {},
    "headers": {}
  },
  "resources": {
    "firm_profile": {
      "request": {
        "body": {
          "dataset": "ReferenceAccount"
        }
      },
      "response_path": "data.dataset_result",
      "record_filters": {},
      "allow_llm_extract": true
    },
    "project_standards": {
      "request": {
        "body": {
          "dataset": "ProjectStandards"
        }
      },
      "response_path": "data.dataset_result",
      "record_filters": {
        "project_type": "{project_type}"
      },
      "allow_llm_extract": true
    },
    "client_relationship": {
      "request": {
        "body": {
          "dataset": "ClientRelationship"
        }
      },
      "response_path": "data.dataset_result",
      "record_filters": {
        "client_name": "{client_name}"
      },
      "allow_llm_extract": true
    }
  }
}
